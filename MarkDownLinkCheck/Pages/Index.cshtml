@page
@model IndexModel
@{
    ViewData["Title"] = "Markdown Link Check";
}

<div class="container mt-4">
    <h1 class="mb-4">Markdown Link Check</h1>
    
    <!-- Mode Selection -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">選擇檢測模式</h5>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="mode" id="modeMarkdown" value="MarkdownSource" checked>
                <label class="form-check-label" for="modeMarkdown">
                    Markdown 原始碼
                </label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="mode" id="modeRepo" value="RepoUrl">
                <label class="form-check-label" for="modeRepo">
                    GitHub Repository URL
                </label>
            </div>
        </div>
    </div>

    <!-- Markdown Source Input -->
    <div id="markdownSourceSection" class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Markdown 內容</h5>
            <textarea id="markdownContent" class="form-control" rows="10" 
                      placeholder="請貼上 Markdown 內容..." maxlength="100000"></textarea>
            <small class="form-text text-muted">
                最多 100,000 字元。目前 <span id="charCount">0</span> 字元。
            </small>
        </div>
    </div>

    <!-- GitHub Repo Input -->
    <div id="repoUrlSection" class="card mb-4" style="display: none;">
        <div class="card-body">
            <h5 class="card-title">GitHub Repository</h5>
            <div class="mb-3">
                <label for="repoUrl" class="form-label">Repository URL</label>
                <input type="url" class="form-control" id="repoUrl" 
                       placeholder="https://github.com/owner/repo" 
                       pattern="https://github\.com/[a-zA-Z0-9\-_.]+/[a-zA-Z0-9\-_.]+" />
                <div class="invalid-feedback">
                    請輸入合法的 GitHub Repository URL
                </div>
            </div>
            <div class="mb-3">
                <label for="branch" class="form-label">分支名稱（選填）</label>
                <input type="text" class="form-control" id="branch" 
                       placeholder="若未指定則使用預設分支" />
            </div>
        </div>
    </div>

    <!-- Start Button -->
    <div class="d-grid gap-2 mb-4">
        <button id="startCheck" class="btn btn-primary btn-lg">
            <i class="bi bi-play-fill"></i> 開始檢測
        </button>
        <button id="cancelCheck" class="btn btn-danger btn-lg" style="display: none;">
            <i class="bi bi-stop-fill"></i> 取消檢測
        </button>
    </div>

    <!-- Progress Bar -->
    <div id="progressSection" style="display: none;">
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">檢測進度</h5>
                <div class="progress mb-2">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" style="width: 0%"></div>
                </div>
                <p id="progressText" class="mb-0">準備中...</p>
            </div>
        </div>
    </div>

    <!-- Error Message -->
    <div id="errorMessage" class="alert alert-danger" role="alert" style="display: none;"></div>

    <!-- File Results -->
    <div id="fileResults" class="mb-4"></div>

    <!-- Report Summary -->
    <div id="reportSummary" class="card" style="display: none;">
        <div class="card-body">
            <h5 class="card-title">檢測報告摘要</h5>
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <div class="stat-label">檔案數量</div>
                        <div class="stat-value" id="summaryFileCount">0</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-success text-white rounded">
                        <div class="stat-label">✅ 正常連結</div>
                        <div class="stat-value" id="summaryHealthy">0</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-danger text-white rounded">
                        <div class="stat-label">❌ 失效連結</div>
                        <div class="stat-value" id="summaryBroken">0</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-warning text-dark rounded">
                        <div class="stat-label">⚠️ 警告</div>
                        <div class="stat-value" id="summaryWarning">0</div>
                    </div>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-secondary text-white rounded">
                        <div class="stat-label">⏭️ 跳過</div>
                        <div class="stat-value" id="summarySkipped">0</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-info text-white rounded">
                        <div class="stat-label">連結總數</div>
                        <div class="stat-value" id="summaryTotal">0</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card text-center p-3 bg-light rounded">
                        <div class="stat-label">總耗時</div>
                        <div class="stat-value" id="summaryDuration">0s</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <button id="copyMarkdown" class="btn btn-outline-primary w-100 h-100">
                        <i class="bi bi-clipboard"></i> 複製為 Markdown
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
}
